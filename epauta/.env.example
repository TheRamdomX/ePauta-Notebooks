# =============================================================================
# Cloudflare R2 Configuration
# =============================================================================

CLOUFLARE_TOKEN_VALUE=your_cloudflare_token_here
# Your Cloudflare Account ID can be found in the R2 dashboard
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# R2 API credentials (create these in Cloudflare dashboard under R2 > Manage R2 API Tokens)
R2_ACCESS_KEY_ID=your_access_key_id_here
R2_SECRET_ACCESS_KEY=your_secret_access_key_here

# The name of your R2 bucket (default: "epauta")
R2_BUCKET_NAME=epauta

# Optional: If you have a custom domain configured for public access
# Leave empty if using signed URLs for private buckets
R2_PUBLIC_DOMAIN=https://yourdomain.com

# =============================================================================
# open-notebook Backend (AI / RAG / Chat)
# =============================================================================

# Base URL of the open-notebook REST API (no trailing slash)
OPEN_NOTEBOOK_API_URL=http://localhost:5055/api

# =============================================================================
# Redis Cache (optional — app works without it)
# =============================================================================

# Development (TCP):
REDIS_URL=redis://localhost:6379

# Production on Vercel — use Upstash Redis (HTTP):
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token
