---
/**
 * Página dinámica para cursos de EII (Ingeniería Industrial).
 * En modo SSR (output: 'server') no se usa getStaticPaths().
 */

import CareerCoursePage from "@/components/CareerCoursePage.astro";
import eii from "@/data/eii/ramos.json";

const { codigo } = Astro.params;

if (!codigo) {
  return Astro.redirect("/eii");
}

const ramo = eii.find((r: { codigo: string; nombre: string }) => r.codigo === codigo);

if (!ramo) {
  return Astro.redirect("/eii");
}
---

<CareerCoursePage carrera="eii" codigo={codigo} nombre={ramo.nombre} />
